"VertexlitGeneric"
{
	"$basetexture" "HUD/status/invulnoverlay"
	"$envmap" "env_cubemap"
	$envmaptint "{255 255 255}"
	//"$vertexalpha" "1"
	//"$vertexcolor" "1"
	$envadd "{64 64 64}"
	$white "[1 1 1]"
	"$selfillum" "1"
	"Proxies"
	{
		"TextureScroll"
		{
			texturescrollvar $baseTextureTransform
			texturescrollrate 1
			texturescrollangle 90
		}
		"Equals"
		{
			srcVar1 $color
			resultVar $selfillumtint
		}
		"Add"
		{
			srcVar1 $color
			srcVar2 $envadd
			resultVar $envmaptint
		}
		"Equals"
		{
			srcVar1 $white
			resultVar $color
		}

	}
}
